@model AccesoCamara
@{
    ViewData["Title"] = $"Cámaras · {Model.Reserva!.Mascota!.Nombre}";
    ViewData["FullScreen"] = true;
    Layout = "_Layout";

    var mascota   = Model.Reserva.Mascota!;
    var cliente   = Model.Reserva.Cliente!;
    var cuidador  = Model.Reserva.Empleado;
    var servicio  = Model.Reserva.TipoServicio;
    var diasEstadia = Model.Reserva.FechaFin is not null
        ? (int)Math.Ceiling((Model.Reserva.FechaFin.Value - Model.Reserva.FechaInicio).TotalDays)
        : 1;
    var diasTranscurridos = (int)Math.Floor((DateTime.Now - Model.Reserva.FechaInicio).TotalDays);
    var urlActual = $"{Context.Request.Scheme}://{Context.Request.Host}/camara/{Model.Token}";
    var msgWhatsApp = Uri.EscapeDataString(
        $"Hola, te compartimos el acceso a las cámaras de VacanJef para que puedas ver a {mascota.Nombre} en tiempo real: {urlActual}");
}
<style>
  body.login-body { overflow:auto; }
  .cam-page { min-height:100vh; background:#0A0A0A; color:#E8E0D0; font-family:"Nunito",sans-serif; padding:0; }
  .cam-topbar { background:#111; border-bottom:1px solid #222; padding:0.6rem 1.2rem; display:flex; align-items:center; justify-content:space-between; }
  .cam-brand { display:flex; align-items:center; gap:0.5rem; font-family:"Syne",sans-serif; font-weight:800; font-size:1rem; color:#F5A623; }
  .cam-brand img { width:32px; height:32px; }
  .cam-status { display:flex; align-items:center; gap:0.5rem; font-size:0.75rem; font-weight:700; color:#6EE7B7; }
  .dot-live { width:8px; height:8px; border-radius:50%; background:#EF4444; animation:blink 1s ease-in-out infinite; }
  @@keyframes blink { 0%,100%{opacity:1} 50%{opacity:.3} }

  .cam-layout { display:grid; grid-template-columns:1fr 320px; height:calc(100vh - 48px); }
  @@media(max-width:900px){ .cam-layout{grid-template-columns:1fr;} .cam-sidebar{display:none;} }

  /* Grid de cámaras */
  .cam-grid { display:grid; grid-template-columns:1fr 1fr; grid-template-rows:1fr 1fr; gap:3px; background:#000; padding:3px; }
  .cam-slot { position:relative; overflow:hidden; background:#0D0D0D; cursor:pointer; }
  .cam-slot.primary { grid-column:1; grid-row:1; }
  .cam-slot:hover .cam-overlay { opacity:1; }

  /* Feed principal animado */
  .cam-feed { width:100%; height:100%; position:relative; background:#0D1A0A; overflow:hidden; }
  .cam-sky  { position:absolute; top:0; left:0; right:0; height:45%; background:linear-gradient(180deg,#1A2A1A 0%,#0D1A0D 100%); }
  .cam-grass{ position:absolute; bottom:0; left:0; right:0; height:40%; background:#0A1A08; border-top:2px solid #1A3A12; }
  .cam-scanlines { position:absolute; inset:0; background:repeating-linear-gradient(0deg,transparent,transparent 3px,rgba(0,0,0,0.08) 3px,rgba(0,0,0,0.08) 4px); pointer-events:none; z-index:5; }
  .cam-noise { position:absolute; inset:0; opacity:0.03; pointer-events:none; z-index:4;
    background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    background-size:200px;
  }

  /* Mascotas animadas */
  .pet-anim { position:absolute; bottom:38%; font-size:clamp(1.4rem,4vw,2.2rem); z-index:6; animation:walk var(--dur,8s) linear infinite var(--delay,0s); }
  @@keyframes walk {
    0%   { left:-10%; transform:scaleX(1); }
    45%  { left:85%; transform:scaleX(1); }
    50%  { left:85%; transform:scaleX(-1); }
    95%  { left:-10%; transform:scaleX(-1); }
    100% { left:-10%; transform:scaleX(1); }
  }
  .pet-anim.bounce { animation-name:bounce-walk; }
  @@keyframes bounce-walk {
    0%,100%{ bottom:38%; left:20%; }
    25%    { bottom:43%; left:50%; }
    50%    { bottom:38%; left:70%; }
    75%    { bottom:43%; left:40%; }
  }

  /* Overlay de cámara */
  .cam-overlay { position:absolute; inset:0; z-index:10; pointer-events:none; transition:opacity 0.2s; }
  .cam-overlay .top { display:flex; justify-content:space-between; padding:6px 8px; }
  .cam-overlay .bottom { position:absolute; bottom:0; left:0; right:0; display:flex; justify-content:space-between; padding:4px 8px; background:linear-gradient(0deg,rgba(0,0,0,0.6),transparent); }
  .cam-label-badge { background:rgba(0,0,0,0.55); border:1px solid rgba(255,255,255,0.1); border-radius:4px; padding:2px 6px; font-size:0.7rem; font-weight:700; color:#ccc; font-family:monospace; }
  .cam-rec { color:#EF4444; font-size:0.7rem; font-weight:800; font-family:monospace; display:flex; align-items:center; gap:4px; }
  .cam-rec::before { content:''; width:6px; height:6px; border-radius:50%; background:#EF4444; display:block; animation:blink 1s ease-in-out infinite; }
  .cam-timestamp { color:rgba(255,255,255,0.7); font-size:0.65rem; font-family:monospace; }
  .pet-name-badge { background:rgba(245,166,35,0.2); border:1px solid rgba(245,166,35,0.4); border-radius:4px; padding:2px 8px; font-size:0.7rem; font-weight:800; color:#F5A623; font-family:monospace; }

  /* Cámaras secundarias */
  .cam-nosignal { display:flex; flex-direction:column; align-items:center; justify-content:center; height:100%; background:#080808; }
  .cam-nosignal span { font-size:1.5rem; margin-bottom:0.3rem; }
  .cam-nosignal p { font-size:0.68rem; font-family:monospace; color:#333; margin:0; }

  /* Sidebar */
  .cam-sidebar { background:#111; border-left:1px solid #1E1E1E; overflow-y:auto; padding:1rem; display:flex; flex-direction:column; gap:1rem; }
  .cam-card { background:#161616; border:1px solid #222; border-radius:10px; padding:1rem; }
  .cam-card-title { font-size:0.7rem; font-weight:800; color:#6B5A3E; text-transform:uppercase; letter-spacing:0.06em; margin-bottom:0.6rem; }
  .pet-avatar { width:56px; height:56px; background:#1A2A1A; border-radius:50%; display:flex; align-items:center; justify-content:center; font-size:1.6rem; margin-bottom:0.5rem; }
  .pet-main-name { font-family:"Syne",sans-serif; font-size:1.1rem; font-weight:800; color:#F5A623; }
  .pet-detail { font-size:0.78rem; color:#7A6A50; font-weight:600; }

  .metric-row { display:flex; justify-content:space-between; align-items:center; padding:0.4rem 0; border-bottom:1px solid #1E1E1E; }
  .metric-row:last-child { border:none; }
  .metric-label { font-size:0.72rem; color:#5A4A30; font-weight:700; text-transform:uppercase; letter-spacing:0.04em; }
  .metric-val { font-size:0.9rem; font-weight:800; color:#E8D0A0; font-family:monospace; }
  .metric-bar { width:60px; height:4px; background:#1E1E1E; border-radius:2px; overflow:hidden; }
  .metric-fill { height:100%; background:linear-gradient(90deg,#F5A623,#FFD166); border-radius:2px; transition:width 1s ease; }

  .share-btn { display:flex; align-items:center; gap:0.5rem; width:100%; padding:0.75rem; border:none; border-radius:9px; font-family:"Nunito",sans-serif; font-weight:800; font-size:0.82rem; cursor:pointer; transition:all 0.2s; }
  .btn-whatsapp { background:#1A3A1A; color:#4ADE80; border:1px solid #2A4A2A; }
  .btn-whatsapp:hover { background:#1F4A1F; }
  .btn-copy { background:#1A1A2A; color:#93C5FD; border:1px solid #2A2A4A; }
  .btn-copy:hover { background:#1F1F3A; }
  .btn-copied { color:#4ADE80 !important; background:#1A3A1A !important; border-color:#2A4A2A !important; }

  .exp-badge { background:#1A1A0A; border:1px solid #2A2A1A; border-radius:8px; padding:0.5rem 0.7rem; font-size:0.72rem; color:#7A6A30; font-weight:700; text-align:center; }
  .exp-badge b { color:#F5A623; }
</style>

<div class="cam-page">
  <!-- Top bar -->
  <div class="cam-topbar">
    <div class="cam-brand">
      <img src="~/images/logo.png" alt="VacanJef">
      VacanJef · Monitoreo
    </div>
    <div class="cam-status">
      <div class="dot-live"></div>
      EN VIVO · @mascota.Nombre · Reserva #@Model.IdReserva
    </div>
    <div style="font-size:0.7rem;color:#4A3A20;font-family:monospace;">
      Acceso válido hasta @Model.FechaExpiracion.ToString("dd/MM/yyyy HH:mm")
    </div>
  </div>

  <div class="cam-layout">
    <!-- Grid de cámaras -->
    <div class="cam-grid">

      <!-- CAM-01: Principal (con la mascota) -->
      <div class="cam-slot primary" id="cam1">
        <div class="cam-feed">
          <div class="cam-sky"></div>
          <div class="cam-grass"></div>
          <!-- Mascotas animadas -->
          <div class="pet-anim" style="--dur:9s;--delay:0s;">🐕</div>
          <div class="pet-anim bounce" style="--dur:12s;--delay:2s;font-size:1.5rem;">🐩</div>
          <div class="pet-anim" style="--dur:7s;--delay:4s;font-size:1.2rem;">🐾</div>
          <!-- Árboles/decoración -->
          <div style="position:absolute;bottom:38%;left:15%;font-size:2rem;z-index:3;">🌿</div>
          <div style="position:absolute;bottom:38%;right:20%;font-size:2.5rem;z-index:3;">🌳</div>
          <div class="cam-noise"></div>
          <div class="cam-scanlines"></div>
          <div class="cam-overlay">
            <div class="top">
              <span class="cam-label-badge">CAM-01 · Patio principal</span>
              <span class="cam-rec">REC</span>
            </div>
            <div class="bottom">
              <span class="pet-name-badge">🐾 @mascota.Nombre</span>
              <span class="cam-timestamp" id="ts1"></span>
            </div>
          </div>
        </div>
      </div>

      <!-- CAM-02: Interior -->
      <div class="cam-slot" id="cam2">
        <div class="cam-feed" style="background:#0A0D1A;">
          <div style="position:absolute;bottom:0;left:0;right:0;height:35%;background:#0D0F1A;border-top:2px solid #1A1F2A;"></div>
          <div class="pet-anim" style="--dur:11s;--delay:1s;font-size:1.6rem;">🦮</div>
          <div class="pet-anim bounce" style="--dur:14s;--delay:3s;font-size:1.2rem;">😺</div>
          <div style="position:absolute;bottom:33%;left:30%;font-size:1.5rem;z-index:3;">🛋️</div>
          <div style="position:absolute;bottom:33%;right:25%;font-size:1.2rem;z-index:3;">🧸</div>
          <div class="cam-noise"></div>
          <div class="cam-scanlines"></div>
          <div class="cam-overlay">
            <div class="top">
              <span class="cam-label-badge">CAM-02 · Sala de descanso</span>
              <span class="cam-rec">REC</span>
            </div>
            <div class="bottom">
              <span class="cam-label-badge" style="color:#ccc;">Interior</span>
              <span class="cam-timestamp" id="ts2"></span>
            </div>
          </div>
        </div>
      </div>

      <!-- CAM-03: Área de juegos -->
      <div class="cam-slot" id="cam3">
        <div class="cam-feed" style="background:#0D0A0A;">
          <div style="position:absolute;bottom:0;left:0;right:0;height:38%;background:#150D0D;border-top:2px solid #2A1A1A;"></div>
          <div class="pet-anim" style="--dur:8s;--delay:0.5s;font-size:2rem;">🐶</div>
          <div class="pet-anim bounce" style="--dur:10s;--delay:5s;font-size:1.1rem;">🎾</div>
          <div style="position:absolute;bottom:36%;left:20%;font-size:1.4rem;z-index:3;">⛲</div>
          <div class="cam-noise"></div>
          <div class="cam-scanlines"></div>
          <div class="cam-overlay">
            <div class="top">
              <span class="cam-label-badge">CAM-03 · Área de juegos</span>
              <span class="cam-rec">REC</span>
            </div>
            <div class="bottom">
              <span class="cam-label-badge" style="color:#ccc;">Exterior</span>
              <span class="cam-timestamp" id="ts3"></span>
            </div>
          </div>
        </div>
      </div>

      <!-- CAM-04: Baño y spa -->
      <div class="cam-slot" id="cam4">
        <div class="cam-feed" style="background:#0A0A15;">
          <div style="position:absolute;bottom:0;left:0;right:0;height:36%;background:#0D0D1A;border-top:2px solid #1A1A2A;"></div>
          <div class="pet-anim bounce" style="--dur:13s;--delay:2.5s;font-size:1.8rem;">🐕‍🦺</div>
          <div style="position:absolute;bottom:34%;left:40%;font-size:1.3rem;z-index:3;">🛁</div>
          <div style="position:absolute;bottom:34%;right:30%;font-size:1rem;z-index:3;">🧴</div>
          <div class="cam-noise"></div>
          <div class="cam-scanlines"></div>
          <div class="cam-overlay">
            <div class="top">
              <span class="cam-label-badge">CAM-04 · Baño y spa</span>
              <span class="cam-rec">REC</span>
            </div>
            <div class="bottom">
              <span class="cam-label-badge" style="color:#ccc;">Servicio</span>
              <span class="cam-timestamp" id="ts4"></span>
            </div>
          </div>
        </div>
      </div>

    </div><!-- /cam-grid -->

    <!-- Sidebar -->
    <div class="cam-sidebar">

      <!-- Mascota -->
      <div class="cam-card">
        <div class="cam-card-title">🐾 Tu mascota</div>
        <div class="pet-avatar">
          @(mascota.Especie.Contains("Gato") ? "🐱" : mascota.Especie.Contains("Ave") ? "🦜" : mascota.Especie.Contains("Conejo") ? "🐰" : "🐕")
        </div>
        <div class="pet-main-name">@mascota.Nombre</div>
        <div class="pet-detail">@mascota.Especie · @(mascota.Raza ?? "—")</div>
        <div class="pet-detail" style="margin-top:4px;">Día @diasTranscurridos de @diasEstadia · @(servicio?.NombreServicio ?? "Estadía")</div>
        @if (cuidador is not null)
        {
          <div class="pet-detail" style="margin-top:6px;color:#5A8A5A;">Cuidador: @cuidador.Nombre @cuidador.Apellido</div>
        }
      </div>

      <!-- Métricas en vivo (SignalR) -->
      <div class="cam-card">
        <div class="cam-card-title">📊 Métricas en vivo</div>
        <div class="metric-row">
          <span class="metric-label">Actividad</span>
          <div style="display:flex;align-items:center;gap:6px;">
            <div class="metric-bar"><div class="metric-fill" id="m-actividad" style="width:60%;"></div></div>
            <span class="metric-val" id="mv-actividad">—</span>
          </div>
        </div>
        <div class="metric-row">
          <span class="metric-label">Temperatura</span>
          <span class="metric-val" id="mv-temp">—</span>
        </div>
        <div class="metric-row">
          <span class="metric-label">Última comida</span>
          <span class="metric-val" id="mv-comida">—</span>
        </div>
        <div class="metric-row">
          <span class="metric-label">Actualizado</span>
          <span class="metric-val" id="mv-hora">—</span>
        </div>
        <div style="margin-top:0.5rem;font-size:0.65rem;color:#3A2A10;text-align:center;">
          Actualización automática cada 4 segundos
        </div>
      </div>

      <!-- Compartir enlace -->
      <div class="cam-card">
        <div class="cam-card-title">📲 Compartir acceso</div>
        <p style="font-size:0.74rem;color:#5A4A30;margin:0 0 0.7rem;">
          Este enlace es exclusivo para @cliente.Nombre @cliente.Apellido.
          Compártelo por WhatsApp o cópialo.
        </p>
        <a class="share-btn btn-whatsapp"
           href="https://wa.me/?text=@msgWhatsApp" target="_blank">
          <span style="font-size:1rem;">💬</span>
          Enviar por WhatsApp
        </a>
        <button class="share-btn btn-copy" style="margin-top:6px;" onclick="copiarEnlace(this)" data-url="@urlActual">
          <span style="font-size:1rem;">🔗</span>
          <span>Copiar enlace</span>
        </button>
        <div style="margin-top:0.6rem;background:#0A0A0A;border-radius:6px;padding:0.4rem 0.5rem;font-size:0.62rem;color:#3A2A10;font-family:monospace;word-break:break-all;">
          @urlActual
        </div>
      </div>

      <!-- Vencimiento -->
      <div class="exp-badge">
        Acceso válido hasta<br>
        <b>@Model.FechaExpiracion.ToString("dd/MM/yyyy") a las @Model.FechaExpiracion.ToString("HH:mm")</b>
      </div>

    </div><!-- /cam-sidebar -->
  </div><!-- /cam-layout -->
</div>

@section Scripts {
<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
<script>
// ── Timestamp en tiempo real ──────────────────────────────
function actualizarTimestamps() {
  const now = new Date();
  const ts  = now.toLocaleString('es-CO', {
    year:'2-digit', month:'2-digit', day:'2-digit',
    hour:'2-digit', minute:'2-digit', second:'2-digit', hour12:false
  });
  ['ts1','ts2','ts3','ts4'].forEach(id => {
    const el = document.getElementById(id);
    if (el) el.textContent = ts;
  });
}
setInterval(actualizarTimestamps, 1000);
actualizarTimestamps();

// ── Copiar enlace ─────────────────────────────────────────
function copiarEnlace(btn) {
  const url = btn.dataset.url;
  navigator.clipboard.writeText(url).then(() => {
    btn.classList.add('btn-copied');
    btn.querySelector('span:last-child').textContent = '¡Copiado!';
    setTimeout(() => {
      btn.classList.remove('btn-copied');
      btn.querySelector('span:last-child').textContent = 'Copiar enlace';
    }, 2500);
  });
}

// ── SignalR: métricas del monitoreo ───────────────────────
const idReserva = @Model.IdReserva;
const conn = new signalR.HubConnectionBuilder()
  .withUrl('/hubs/monitoreo')
  .withAutomaticReconnect()
  .build();

conn.on('metricaActualizada', m => {
  if (m.idReserva !== idReserva) return;
  const act = m.nivelActividad;
  document.getElementById('mv-actividad').textContent = act + '%';
  document.getElementById('m-actividad').style.width = act + '%';
  document.getElementById('mv-temp').textContent     = m.temperaturaC + '°C';
  document.getElementById('mv-comida').textContent   = m.ultimaComida;
  document.getElementById('mv-hora').textContent     = m.timestamp;
});

conn.start()
  .then(() => conn.invoke('UnirseAReserva', idReserva))
  .catch(err => console.warn('SignalR no disponible:', err));
</script>
}
